# Copy this to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
APP_BASE_DOMAIN=yourdomain.com
ENCRYPTION_KEY=your_32_character_encryption_key

# Stripe Connect (Required for payments)
# For development (test mode)
STRIPE_SECRET_KEY_TEST=sk_test_***
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_***
STRIPE_CLIENT_ID_TEST=ca_test_***

# For production (live mode)
STRIPE_SECRET_KEY_LIVE=sk_live_***
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_***  # Use live publishable key in production
STRIPE_CLIENT_ID_LIVE=ca_live_***  # Use live client ID in production

# App configuration
NEXT_PUBLIC_ROOT_URL=https://yourdomain.com
# Pin Stripe API version; only bump deliberately (release task). Default in code if unset.
STRIPE_API_VERSION=2025-09-30.clover

# Optional: Force live mode in development
# STRIPE_MODE=live

# Optional: For development
NEXT_PUBLIC_APP_BASE_DOMAIN=localhost:3002
NEXT_PUBLIC_SITES_BASE_DOMAIN=http://localhost:3002

# Email Ingest (Cloudflare Worker → Parking Channel)
# Shared secret that must match the Cloudflare Worker variable INGEST_SECRET
INGEST_SECRET=pc_ingest_change_me_to_long_random

# Cron/Job endpoints (stop bots and accidental calls)
# Schedulers (Cloudflare Cron, GitHub Actions, cron-job.org) send header: x-job-secret: <value>
JOB_SECRET=change_me_to_long_random_secret

# Internal cron / one-off jobs (e.g. process-one email reprocess)
# Send header: Authorization: Bearer <value> or x-internal-cron-key: <value>
INTERNAL_CRON_KEY=change_me_to_long_random_secret
